# Local dev: copy to .env (Railway sets these in its dashboard instead).
NODE_ENV=development      # set to "production" on Railway (enables Secure cookies)
PORT=8080                 # Railway injects its own PORT automatically
DATA_DIR=./data           # where per-tenant WhatsApp auth is stored
DB_PATH=./data/app.db     # SQLite file
APP_SECRET=               # REQUIRED in prod: encrypts stored Cloud API tokens + Attio keys at rest

# AI-personalized openers (optional). Without this, campaigns fall back to the plain template.
ANTHROPIC_API_KEY=                 # sk-ant-...
AI_MODEL=claude-3-haiku-20240307   # dirt-cheap default; override for more quality
ATTIO_API_KEY=                    # attio_...

# MCP server (src/mcp.ts) talks to the running web app's REST API:
# WA_API_URL=http://localhost:8080
# WA_API_TOKEN=wa_...      # copy from the dashboard → "API token"
