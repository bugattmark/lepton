# WA Connect (lepton.live) — environment configuration.
#
# Local dev: copy to .env (`cp .env.example .env`). On Railway, set these in the
# dashboard instead. Everything below is OPTIONAL except APP_SECRET in production —
# the app boots with zero keys and every integration degrades when its key is absent
# (the matching `xAvailable()` check returns false and that feature is skipped).
# Where a key is missing for a feature you actually use, the failure surfaces in the
# UI rather than silently no-op'ing.

# ─── Core runtime ──────────────────────────────────────────────────────────────
NODE_ENV=development      # set to "production" on Railway (enables Secure cookies)
PORT=8080                 # Railway injects its own PORT automatically
DATA_DIR=./data           # where per-tenant WhatsApp (Baileys) auth state is stored — src/sessions.ts
DB_PATH=./data/app.db     # SQLite file — src/db.ts

# REQUIRED IN PRODUCTION. AES-256-GCM key that encrypts stored Cloud API tokens &
# per-tenant Attio keys at rest (src/secret.ts). Use a long random string. Without
# it, secrets are stored as plaintext (backward-compatible, but do not ship that).
APP_SECRET=

# ─── Claude: AI-personalized openers + website research (src/ai.ts) ────────────
# When set, campaigns send a Claude-tailored WhatsApp opener (reading any website
# URLs in the contact's mapped fields). Without it, campaigns fall back to the
# plain rendered template — sending still works.
ANTHROPIC_API_KEY=                 # sk-ant-...
AI_MODEL=claude-3-haiku-20240307   # dirt-cheap default; override for quality (e.g. claude-haiku-4-5)

# ─── OpenAI: lead pipeline + pitch generation ──────────────────────────────────
# One key powers FOUR features, each best-effort and skipped without it:
#   • phone sourcing  — IG handle → WhatsApp phone via hosted web_search (src/iglead.ts)
#   • qualify         — score/tier each lead 0–100 (src/qualify.ts)
#   • dedupe          — LLM consolidation pass over sourced rows (src/dedupe.ts)
#   • pitch gen       — generate pitch copy (src/pitchgen.ts)
# NOTE: these use the OpenAI *Responses* API + the hosted `web_search` tool, so an
# OpenRouter key is NOT a drop-in replacement here.
OPENAI_API_KEY=                    # sk-...
IGLEAD_MODEL=gpt-5.4               # model for iglead/qualify/dedupe; do NOT use a -mini tier (skips web_search → ~1% recall)
IGLEAD_EFFORT=medium              # reasoning effort for phone lookup: none|low|medium|high|xhigh
PITCH_MODEL=gpt-5.4-mini          # model for pitch generation (src/pitchgen.ts)

# ─── HikerAPI: Instagram niche sourcing (src/sourcing.ts) ──────────────────────
# Discovers candidate handles from IG hashtags and enriches them. Required for the
# "source leads from a niche" flow; phone lookup on those leads also needs OPENAI_API_KEY.
HIKER_API_KEY=

# ─── Instagram Business Login: real follower demographics (src/instagram.ts) ───
# The creator connects their OWN IG account (OAuth → 60-day token → demographics).
# Both required to enable the "Connect Instagram" button. Register the callback in
# the Meta App Dashboard.
IG_APP_ID=
IG_APP_SECRET=
# Optional: only set if the OAuth callback is hosted somewhere other than this app's
# own host. Defaults to {request-host}/auth/instagram/callback. Must match the Meta App.
IG_REDIRECT_URI=

# ─── "Continue with Google" + Gmail read/send (src/google.ts) ──────────────────
# Both required to enable Google sign-in / sign-up and Gmail connect. Register the
# callback on the OAuth client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: only set if the callback is hosted elsewhere. Defaults to
# {request-host}/auth/google/callback. Must exactly match one registered on the client.
GOOGLE_REDIRECT_URI=

# ─── Attio CRM ─────────────────────────────────────────────────────────────────
# NOT configured here. Each tenant pastes their own Attio API key in the dashboard;
# it is encrypted (APP_SECRET) and stored per-tenant in the DB — never an env var.

# ─── Brand-seed ingest (TEMP, src/server.ts /api/seed/bento) ───────────────────
# One-off secret-gated endpoint that ingests normalized brands from the in-browser
# onbento harvester. Set SEED_SECRET to enable it (sent as the x-seed-secret header).
# Slated for removal once the brands table is seeded.
SEED_SECRET=
SEED_ALLOW_ORIGIN=https://app.onbento.com   # CORS origin allowed to call the seed endpoint

# ─── Planned external data sources — NOT yet wired ─────────────────────────────
# Proposed in docs/superpowers/specs/2026-06-07-external-data-sources-design.md.
# No code reads these yet; uncomment + fill only as each stage is built. Left here
# (commented) as a roadmap, not as live config — keeping with "no stubbed config".
#
# APIFY_TOKEN=         # Apify scraping actors. Stage 2 brand-matching (Meta Ad-Library
#                      # branded-content → creator_brand_deals, src/deals.ts) + Stage 1
#                      # cross-platform reach (TikTok/YouTube/social-finder actors).
# EXA_API_KEY=         # Exa neural web search (src/exa.ts). Stage 3 rate_cards seeding
#                      # (offline, cited provenance), Stage 1 creator web footprint,
#                      # Stage 2 net-new discovery + influencer-marketing absence cross-check.

# ─── MCP server (src/mcp.ts) — drives the running app over its own REST API ─────
# WA_API_URL=http://localhost:8080
# WA_API_TOKEN=wa_...      # copy from the dashboard → "API token"
